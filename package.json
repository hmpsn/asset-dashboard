    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
