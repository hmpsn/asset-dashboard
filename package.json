{
  "name": "asset-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server/index.ts",
    "dev:all": "concurrently -n server,ui -c blue,green \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "start": "NODE_ENV=production node --import tsx server/index.ts",
    "db:migrate": "tsx server/db/migrate-json.ts",
    "db:sync-staging": "tsx scripts/sync-staging-db.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "phase2:baseline": "playwright test --config=playwright.visual.config.ts",
    "phase2:baseline:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "pr-check": "tsx scripts/pr-check.ts",
    "pr-check:all": "tsx scripts/pr-check.ts --all",
    "verify:organization": "tsx scripts/report-platform-organization.ts",
    "verify:coverage-baseline": "tsx scripts/report-critical-domain-coverage.ts",
    "verify:ai-reliability": "tsx scripts/report-ai-reliability.ts",
    "verify:ai-pipeline-wiring": "tsx scripts/report-ai-pipeline-wiring.ts",
    "verify:coverage-ratchet": "tsx scripts/report-coverage-ratchet.ts",
    "verify:domain-events": "tsx scripts/report-domain-event-definitions.ts",
    "verify:product-surface": "tsx scripts/product-surface-map.ts",
    "verify:data-integrity": "tsx scripts/report-data-integrity-recovery.ts",
    "verify:observability": "tsx scripts/report-platform-observability.ts",
    "verify:platform": "tsx scripts/verify-platform.ts",
    "verify:platform:quick": "tsx scripts/verify-platform.ts --quick",
    "rules:generate": "tsx scripts/generate-rules-doc.ts",
    "prepare": "husky",
    "verify:release-safety": "tsx scripts/platform-release-safety.ts",
    "report:release-safety": "tsx scripts/report-release-safety.ts",
    "verify:tenant-boundary": "tsx scripts/platform-tenant-boundary-audit.ts",
    "report:tenant-boundary": "tsx scripts/report-tenant-boundary-audit.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.1009.0",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/node": "^10.43.0",
    "@sentry/react": "^10.43.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.95.0",
    "@tiptap/extension-bubble-menu": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/compression": "^1.8.1",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.576.0",
    "multer": "^2.1.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.1",
    "openai": "^6.25.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "svgo": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
