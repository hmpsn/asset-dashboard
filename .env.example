# ═══════════════════════════════════════════════════════════════════════
# Asset Dashboard — Environment Variables
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ── Required — AI providers ──
ANTHROPIC_API_KEY=sk-...       # Anthropic Claude — admin chat, content generation
OPENAI_API_KEY=sk-...          # OpenAI — SEO analysis, alt text, schema suggestions, content briefs

# ── Required — Webflow CMS ──
WEBFLOW_API_TOKEN=...          # Webflow API v2 token (fallback; per-workspace tokens override this)

# ── Security (required in production) ──
JWT_SECRET=                    # Secret for signing admin & client JWTs. MUST be set in prod — falls back to an insecure hardcoded value in dev.
SESSION_SECRET=                # HMAC secret for client dashboard sessions (falls back to APP_PASSWORD, then random)

# ── Google — Search Console / GA4 integration (optional) ──
GOOGLE_CLIENT_ID=              # Google Cloud OAuth2 client ID
GOOGLE_CLIENT_SECRET=          # Google Cloud OAuth2 client secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback  # OAuth callback URL — change per environment

# ── Google — PageSpeed Insights (optional) ──
GOOGLE_PSI_KEY=                # Google PageSpeed Insights API key (also accepts GOOGLE_API_KEY)

# ── SEMRush (optional) ──
SEMRUSH_API_KEY=               # SEMRush API key — keyword research, competitor analysis, domain analytics

# ── Stripe payments (optional — leave blank to disable payment flows) ──
STRIPE_SECRET_KEY=             # sk_test_... or sk_live_...
STRIPE_PUBLISHABLE_KEY=        # pk_test_... or pk_live_... (exposed to client checkout UI)
STRIPE_WEBHOOK_SECRET=         # whsec_... from Stripe Dashboard → Webhooks
STRIPE_PRICE_BRIEF=            # price_... for content briefs
STRIPE_PRICE_POST_DRAFT=       # price_... for AI draft blog post
STRIPE_PRICE_POST_POLISHED=    # price_... for polished blog post
STRIPE_PRICE_POST_PREMIUM=     # price_... for premium blog post
STRIPE_PRICE_SCHEMA_PAGE=      # price_... for per-page schema
STRIPE_PRICE_SCHEMA_SITE=      # price_... for full-site schema
STRIPE_PRICE_STRATEGY=         # price_... for keyword strategy
STRIPE_PRICE_STRATEGY_REFRESH= # price_... for strategy refresh

# ── Email / SMTP (optional — leave blank to disable all email notifications) ──
SMTP_HOST=                     # e.g. smtp.gmail.com, smtp.postmarkapp.com
SMTP_PORT=587                  # 587 for STARTTLS, 465 for SSL
SMTP_USER=                     # SMTP username / email
SMTP_PASS=                     # SMTP password or app-specific password
SMTP_FROM=                     # From address (defaults to SMTP_USER if blank)
SMTP_FROM_NAME=                # Display name for outgoing emails (e.g. "hmpsn studio")
NOTIFICATION_EMAIL=            # Where admin/team notifications are sent (your inbox)

# ── Deployment & hosting (optional — set for hosted environments) ──
APP_URL=                       # Platform base URL for email links (e.g. https://app.hmpsn.studio). NOT the client's website domain.
APP_PASSWORD=                  # Password gate for the admin dashboard (leave blank to disable)
DATA_DIR=                      # Base directory for all data storage (default: ~/.asset-dashboard in dev, /tmp/asset-dashboard in prod)
PORT=3001                      # Server port (default: 3001, Railway/Render set this automatically)
ALLOWED_ORIGINS=               # Comma-separated list of allowed CORS origins (leave blank to allow all in dev)

# ── Error monitoring — Sentry (optional — leave blank to disable) ──
SENTRY_DSN=                    # Sentry DSN for server-side error tracking
VITE_SENTRY_DSN=               # Sentry DSN for frontend error tracking (exposed to browser)
SENTRY_AUTH_TOKEN=             # Sentry auth token for source map uploads during build
SENTRY_ORG=                    # Sentry organization slug
SENTRY_PROJECT=                # Sentry project slug

# ── Backups (optional) ──
BACKUP_DIR=                    # Custom backup directory (default: DATA_DIR/backups or ~/.asset-dashboard/backups)
BACKUP_RETENTION_DAYS=7        # Number of days to keep backup files (default: 7)

# ── Off-site backups (optional — S3-compatible storage) ──
BACKUP_S3_BUCKET=              # S3 bucket name for off-site backups (leave blank to disable)
BACKUP_S3_REGION=us-east-1     # AWS region for the backup bucket
BACKUP_S3_PREFIX=backups       # S3 key prefix for backup archives (default: backups)
AWS_ACCESS_KEY_ID=             # AWS credentials (or use IAM role on EC2/ECS)
AWS_SECRET_ACCESS_KEY=
